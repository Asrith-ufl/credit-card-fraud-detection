    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from xgboost import XGBClassifier\n",
        "from sklearn.neural_network import MLPClassifier\n",
        "from sklearn.metrics import classification_report, roc_auc_score\n",
        "\n",
        "# Store results\n",
        "results = {}\n",
        "\n",
        "# 1. Logistic Regression\n",
        "print(\"Training Logistic Regression...\")\n",
        "lr = LogisticRegression(max_iter=1000, random_state=42)\n",
        "lr.fit(X_train_resampled, y_train_resampled)\n",
        "lr_pred = lr.predict(X_test_scaled)\n",
        "results['Logistic Regression'] = {\n",
        "    'model': lr,\n",
        "    'predictions': lr_pred,\n",
        "    'auc': roc_auc_score(y_test, lr.predict_proba(X_test_scaled)[:,1])\n",
        "}\n",
        "print(f\"Logistic Regression AUC: {results['Logistic Regression']['auc']:.4f}\\n\")\n",
        "\n",
        "# 2. Random Forest\n",
        "print(\"Training Random Forest...\")\n",
        "rf = RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)\n",
        "rf.fit(X_train_resampled, y_train_resampled)\n",
        "rf_pred = rf.predict(X_test_scaled)\n",
        "results['Random Forest'] = {\n",
        "    'model': rf,\n",
        "    'predictions': rf_pred,\n",
        "    'auc': roc_auc_score(y_test, rf.predict_proba(X_test_scaled)[:,1])\n",
        "}\n",
        "print(f\"Random Forest AUC: {results['Random Forest']['auc']:.4f}\\n\")\n",
        "\n",
        "# 3. XGBoost\n",
        "print(\"Training XGBoost...\")\n",
        "xgb = XGBClassifier(n_estimators=100, random_state=42, eval_metric='logloss')\n",
        "xgb.fit(X_train_resampled, y_train_resampled)\n",
        "xgb_pred = xgb.predict(X_test_scaled)\n",
        "results['XGBoost'] = {\n",
        "    'model': xgb,\n",
        "    'predictions': xgb_pred,\n",
        "    'auc': roc_auc_score(y_test, xgb.predict_proba(X_test_scaled)[:,1])\n",
        "}\n",
        "print(f\"XGBoost AUC: {results['XGBoost']['auc']:.4f}\\n\")\n",
        "\n",
        "# 4. Neural Network\n",
        "print(\"Training Neural Network...\")\n",
        "nn = MLPClassifier(hidden_layer_sizes=(64, 32), max_iter=500, random_state=42)\n",
        "nn.fit(X_train_resampled, y_train_resampled)\n",
        "nn_pred = nn.predict(X_test_scaled)\n",
        "results['Neural Network'] = {\n",
        "    'model': nn,\n",
        "    'predictions': nn_pred,\n",
        "    'auc': roc_auc_score(y_test, nn.predict_proba(X_test_scaled)[:,1])\n",
        "}\n",
        "print(f\"Neural Network AUC: {results['Neural Network']['auc']:.4f}\\n\")\n",
        "\n",
        "print(\"All models trained!\")"
      ],
      "metadata": {
        "id": "kJ_mS0aKB5x2",
        "outputId": "c754325c-d493-4957-d382-63d2f1012df1",
